# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"

# Admin Authentication
ADMIN_PASSWORD="changeme-secure-password"
ADMIN_JWT_SECRET="changeme-very-long-random-secret-key-at-least-32-chars"

# Resend Email API
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@mackayceoforums.com"
ADMIN_EMAIL="admin@mackayceoforums.com"

# HubSpot CRM (optional - for contact pre-fill)
HUBSPOT_API_KEY="pat-xxxxxxxxxxxx"

# Cloudflare R2 (optional - for logo storage; falls back to local /public/logos)
CLOUDFLARE_R2_ACCOUNT_ID="xxxxxxxxxxxx"
CLOUDFLARE_R2_ACCESS_KEY_ID="xxxxxxxxxxxx"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="xxxxxxxxxxxx"
CLOUDFLARE_R2_BUCKET="mackay-logos"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
